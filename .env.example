# ============================================================
# NoneBot2 基础配置
# ============================================================
SUPERUSER=123456

# ============================================================
# OBLP 配置 (前缀 OBLP_)
# ============================================================
OBLP_STORE_TYPE=sqlite
OBLP_SQLITE_PATH=./data/oblp/permissions.db
OBLP_REDIS_URL=redis://localhost:6379/0

# 角色默认权限节点
OBLP_DEFAULT_GROUP_OWNER='["luckperms.help"]'
OBLP_DEFAULT_GROUP_ADMIN='[]'
OBLP_DEFAULT_GROUP_MEMBER='[]'
OBLP_SUPERUSER_INHERIT='["luckperms.*"]'

# 缓存
OBLP_CACHE_TTL=300

# 消息文件路径 (YAML, 支持占位符)
OBLP_MESSAGE_FILE=./data/oblp/messages.yml

# 调试
OBLP_DEBUG_MODE=false
